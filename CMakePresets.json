{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "17",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON"
            }
        },
        {
            "name": "x64",
            "displayName": "64-bit",
            "description": "64-bit Windows build",
            "inherits": "base",
            "architecture": "x64"
        },
        {
            "name": "x86",
            "displayName": "32-bit",
            "description": "32-bit Windows build",
            "inherits": "base",
            "architecture": "Win32"
        }
    ],
    "buildPresets": [
        {
            "name": "x64-release",
            "displayName": "64-bit Release",
            "description": "64-bit Release build",
            "configurePreset": "x64",
            "configuration": "Release"
        },
        {
            "name": "x64-debug",
            "displayName": "64-bit Debug",
            "description": "64-bit Debug build",
            "configurePreset": "x64",
            "configuration": "Debug"
        },
        {
            "name": "x86-release",
            "displayName": "32-bit Release",
            "description": "32-bit Release build",
            "configurePreset": "x86",
            "configuration": "Release"
        },
        {
            "name": "x86-debug",
            "displayName": "32-bit Debug",
            "description": "32-bit Debug build",
            "configurePreset": "x86",
            "configuration": "Debug"
        }
    ]
}
